# Skopiuj do pliku .env i uzupełnij (pliku .env nie commitujemy).
# Supabase → Project Settings → API

SUPABASE_URL=https://twoj-projekt.supabase.co
SUPABASE_SERVICE_ROLE_KEY=twoj-klucz-service-role

# Vercel: te same zmienne ustaw w Project → Settings → Environment Variables
# (Production / Preview). Nie wgrywaj .env do repozytorium.

# Opcjonalnie: skraper OBI (przycisk „OBI Zapasy”). Jeśli ustawisz SCRAPER_TOKEN, nagłówek X-Scraper-Token musi być identyczny.
# Jeśli NIE ustawisz SCRAPER_TOKEN, użytkownik w przeglądarce podaje własny sekret (min. 24 zn.) — zapis w localStorage.
# SCRAPER_TOKEN=
# SCRAPE_ALLOWED_HOSTS=www.obi.de,obi.de
