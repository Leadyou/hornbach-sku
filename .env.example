# Skopiuj do pliku .env i uzupełnij (pliku .env nie commitujemy).
# Supabase → Project Settings → API

SUPABASE_URL=https://twoj-projekt.supabase.co
SUPABASE_SERVICE_ROLE_KEY=twoj-klucz-service-role

# Vercel: te same zmienne ustaw w Project → Settings → Environment Variables
# (Production / Preview). Nie wgrywaj .env do repozytorium.

# Opcjonalnie: skraper OBI — tylko te hosty (nie otwieramy całego internetu z Twojego serwera).
# SCRAPE_ALLOWED_HOSTS=www.obi.de,obi.de
#
# SCRAPER_REQUIRE_TOKEN=1 — wymaga nagłówka X-Scraper-Token na endpointach skrapera.
#   SCRAPER_PIN — krótkie hasło dla zespołu (min. 8 znaków); to samo wpisują współpracownicy w UI (nie commituj).
#   SCRAPER_TOKEN — opcjonalny długi sekret (CI, curl); nagłówek musi być identyczny.
#   Wystarczy jedno z dwóch (PIN lub TOKEN); możesz ustawić oba.
# SCRAPER_REQUIRE_TOKEN=1
# SCRAPER_PIN=twoj-pin
# SCRAPER_TOKEN=
